<% layout("/layouts/boilerplate") %>
<body>
     <div class="row mt-3">
        <div class="col-8 offset-2">
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings" novalidate class=" needs-validation" enctype="multipart/form-data">
        <div class="md-3">
            <label for="title" class="form-label">Title</label>
             <input name="title" placeholder="enter title" type="text" class="form-control"
             required />
             <div class="valid-feedback">Looks good!</div> 
         
        </div>
        
         <div class="md-3">
             <label for="image" class="form-label">Image URL</label>
             <input name="image" placeholder="Provide URl" type="link" class="form-control" /><br />
             
             <input name="image"  type="file" class="form-control" required /><br />
             <div class="invalid-feedback">Please upload an image file.</div>
        <div class="md-3">
            <label for="description" class="form-label">Description</label>
            <input name="description" placeholder="enter description" type="text" class="form-control" />
        </div>
        <div class="md-3">
            <label for="price" class="form-label">Price</label>
            <input name="price" placeholder="enter price" type="number" class="form-control"
             required />
              <div class="invalid-feedback">Please provide a valid price.</div> 
        </div>
      
       
        <div class="md-3">
            <label for="location" class="form-label">Location</label>
             <input name="location" placeholder="enter location" type="text" class="form-control" required />
              <div class="invalid-feedback">Please provide a valid location.</div> 
        </div>
       <div class="md-3">
            <label for="country" class="form-label">Country</label>
        <input name="country" placeholder="enter country" type="text" class="form-control" required />
         <div class="invalid-feedback">Please provide a valid country.</div> 
       </div>
       
        <button type="submit" class="btn btn-dark createbtn mt-3 mb-3">Create Listing</button>
        </form>
         </div>
    </div>
</body>
<% layout("/layouts/boilerplate") %>